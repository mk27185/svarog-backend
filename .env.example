# PostgreSQL — buď DATABASE_URL, nebo všechny proměnné níže (bez výchozího hesla).
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/svarog_dev

# Redis — buď REDIS_URL, nebo REDIS_HOST + REDIS_PORT (port povinně).
REDIS_URL=redis://127.0.0.1:6379

# HTTP
PORT=3000

# První admin účet: po registraci nastav role v DB (UPDATE users SET role = 'admin' ...).
