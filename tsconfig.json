{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@db/*": ["src/db/*"],
      "@redis/*": ["src/redis/*"],
      "@trpc/*": ["src/trpc/*"]
    }
  },
  "include": ["src/**/*.ts", "drizzle.config.ts"]
}
